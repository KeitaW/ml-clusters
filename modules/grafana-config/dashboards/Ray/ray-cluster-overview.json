{
  "title": "Ray Cluster Overview",
  "uid": "ray-cluster-overview",
  "editable": true,
  "timezone": "utc",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Active Nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "ray_cluster_active_nodes",
          "legendFormat": "{{ NodeType }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Running Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "sum(ray_tasks{State=\"RUNNING\"})",
          "legendFormat": "Running"
        }
      ]
    },
    {
      "title": "Running Actors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "sum(ray_actors{State=\"ALIVE\"})",
          "legendFormat": "Alive"
        }
      ]
    },
    {
      "title": "Pending Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "sum(ray_tasks{State=\"PENDING_NODE_ASSIGNMENT\"}) or vector(0)",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "CPU Utilization per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "ray_node_cpu_utilization",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Memory Utilization per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "ray_node_mem_used / ray_node_mem_total * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "GPU Utilization (DCGM)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "{{ gpu }} - {{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "GPU Memory Used (DCGM)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "{{ gpu }} - {{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "title": "Object Store Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "__PROMETHEUS_UID__" },
      "targets": [
        {
          "expr": "ray_object_store_memory",
          "legendFormat": "Used - {{ instance }}"
        },
        {
          "expr": "ray_object_store_available_memory",
          "legendFormat": "Available - {{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Ray Dashboard",
      "type": "text",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": {
        "mode": "markdown",
        "content": "## Quick Links\n\n- Access the Ray Dashboard directly via the Ray head node service\n- Check `/api/cluster_status` for detailed cluster state\n- Use `ray status` from the head node for CLI diagnostics"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
