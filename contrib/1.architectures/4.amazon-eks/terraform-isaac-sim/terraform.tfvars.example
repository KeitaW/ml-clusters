cluster_name       = "isaac-sim-eks"
cluster_version    = "1.31"
region             = "us-west-2"
gpu_instance_types = ["g5.2xlarge", "g5.4xlarge", "g6.2xlarge"]
max_gpu_nodes      = 4

# Training NodePool — targets capacity reservation for X-Mobility training
training_instance_type  = "p6-b300.48xlarge"
max_training_gpus       = 48
capacity_reservation_id = "cr-060a52a865d1673d0"

tags = {
  "project"     = "osmo-amr-pipeline"
  "environment" = "dev"
}
